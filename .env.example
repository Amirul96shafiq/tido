APP_NAME=tido
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Mobile (same Wi-Fi): set to http://<PC-LAN-IP>:2000 e.g. http://192.168.1.10:2000
# Find IP with: ipconfig (Windows) → IPv4 Address. Restart npm run dev:full after changing.

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Ollama (receipt vision OCR) — native host install, no Docker
# See docs/ollama-setup.md
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5vl:7b
OLLAMA_TIMEOUT=120

# Evolution API (WhatsApp) — host process via `npm run evolution`
# See docs/evolution-local-windows.md
EVOLUTION_API_URL=http://127.0.0.1:8080
# Must match Evolution AUTHENTICATION_API_KEY exactly (use a long random secret in real use)
EVOLUTION_API_KEY=tido-secret-key
EVOLUTION_INSTANCE_NAME=tido
# Digits only, e.g. 60123456789 — must match admin User.phone for OTP login / panel
PERSONAL_WHATSAPP_NUMBER=
# Optional: extra numbers that may talk to the bot / send receipts (not for login)
# Comma/space/semicolon separated, e.g. 60111111111,60122222222
PERSONAL_WHATSAPP_EXTRA_NUMBERS=
# Seconds to wait after the last saved WhatsApp receipt before sending a batched "Document received" ack
WHATSAPP_DOCUMENT_RECEIVED_DEBOUNCE_SECONDS=3
# Base URL for WhatsApp file/edit links (must be reachable from your phone). Example: http://192.168.1.10:2000
# When empty and APP_URL is localhost, tido tries your LAN IP automatically.
WHATSAPP_PUBLIC_APP_URL=
# Optional: path to Evolution clone for `npm run evolution` (default ../evolution-api)
# EVOLUTION_PATH=../evolution-api
